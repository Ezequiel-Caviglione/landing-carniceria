      "html": "\n<style data-kid=\"0\">\n    @import url('https://fonts.googleapis.com/css2?family=Bevan&family=Kalam:wght@300;400;700&family=Inter:wght@400;500;600&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n    :root {\n        --floral-white: #FFFAF0;\n        --classic-crimson: #DC143C;\n        --charcoal: #555555;\n        --chalk: rgba(255, 255, 255, 0.85);\n    }\n\n    body {\n        background-color: var(--floral-white);\n        color: var(--charcoal);\n        font-family: 'Inter', sans-serif;\n        overflow-x: clip;\n    }\n\n    .font-bevan { font-family: 'Bevan', serif; }\n    .font-kalam { font-family: 'Kalam', cursive; }\n    .font-sans { font-family: 'Inter', sans-serif; }\n\n    /* Washi Tape Effect */\n    .washi-tape {\n        position: relative;\n    }\n    .washi-tape::before {\n        content: '';\n        position: absolute;\n        top: -8px;\n        left: -4px;\n        width: 110%;\n        height: 18px;\n        background: rgba(220, 200, 100, 0.45);\n        transform: rotate(-1.5deg);\n        z-index: -1;\n        pointer-events: none;\n    }\n\n    /* Locomotive Reveal Styles */\n    [data-scroll] {\n        opacity: 0;\n        transform: translateY(30px);\n        transition: opacity 0.8s ease-out, transform 0.8s ease-out;\n    }\n    [data-scroll].is-inview {\n        opacity: 1;\n        transform: translateY(0);\n    }\n\n    /* Newspaper specific styling */\n    .newspaper-container {\n        box-shadow: 0 20px 50px rgba(0,0,0,0.1);\n    }\n\n    /* Custom scrollbar for better retro feel */\n    ::-webkit-scrollbar {\n        width: 12px;\n    }\n    ::-webkit-scrollbar-track {\n        background: var(--floral-white);\n    }\n    ::-webkit-scrollbar-thumb {\n        background: var(--classic-crimson);\n        border: 3px solid var(--floral-white);\n        border-radius: 10px;\n    }\n\n    .cursor-blink {\n        display: inline-block;\n        width: 8px;\n        height: 1em;\n        background-color: var(--classic-crimson);\n        margin-left: 4px;\n        vertical-align: baseline;\n    }\n</style>\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css\" data-kid=\"1\">\n\n<main data-scroll-container data-kid=\"2\">\n    \n    <nav class=\"sticky top-0 z-50 flex items-center justify-between px-6 py-4 bg-white/95 backdrop-blur-sm border-b-4 border-[var(--classic-crimson)]\" data-kid=\"3\">\n        <div class=\"flex items-center gap-3\" data-kid=\"4\">\n            <div class=\"w-10 h-10 bg-[var(--classic-crimson)] flex items-center justify-center rounded-xs shadow-[3px_3px_0px_var(--charcoal)]\" data-kid=\"5\">\n                <i class=\"ti ti-meat text-white text-xl\" data-kid=\"6\"></i>\n            </div>\n            <span class=\"font-bevan text-xl md:text-2xl text-[var(--charcoal)] tracking-tight\" data-kid=\"7\">Carnicería El Barrio</span>\n        </div>\n        \n        <div class=\"hidden md:flex items-center gap-10\" data-kid=\"8\">\n            <a href=\"#carnes\" class=\"text-lg font-kalam font-bold hover:text-[var(--classic-crimson)] transition-colors\" data-kid=\"9\">Carnes</a>\n            <a href=\"#historia\" class=\"text-lg font-kalam font-bold washi-tape\" data-kid=\"10\">Historia</a>\n            <a href=\"#contacto\" class=\"text-lg font-kalam font-bold hover:text-[var(--classic-crimson)] transition-colors\" data-kid=\"11\">Contacto</a>\n        </div>\n\n        <button class=\"bg-[var(--classic-crimson)] text-white px-5 py-2 md:px-6 md:py-3 font-bevan rounded-sm shadow-[4px_4px_0px_var(--charcoal)] hover:translate-x-[1px] hover:translate-y-[1px] hover:shadow-[2px_2px_0px_var(--charcoal)] transition-all cursor-pointer\" data-kid=\"12\">\n            Llamar Ahora\n        </button>\n    </nav>\n\n    \n    <section class=\"relative min-h-[90vh] flex flex-col lg:flex-row overflow-hidden\" data-kid=\"13\">\n        \n        <div class=\"flex-1 p-8 md:p-16 lg:p-24 flex flex-col justify-center items-start z-10 bg-[var(--floral-white)]\" data-kid=\"14\">\n            <h1 class=\"font-bevan text-6xl md:text-7xl lg:text-8xl text-[var(--classic-crimson)] leading-none mb-6\" data-kid=\"15\">\n                LA CARNE DE <br data-kid=\"16\"> TU BARRIO, <br data-kid=\"17\"> COMO ANTES\n            </h1>\n            <p class=\"font-kalam text-2xl md:text-3xl text-[var(--charcoal)] max-w-lg leading-relaxed mb-10\" data-kid=\"18\">\n                Seleccionamos cada pieza con el cuidado de antaño. Tradición familiar directa a su mesa.\n            </p>\n            <button id=\"hero-cta-btn\" class=\"bg-[var(--classic-crimson)] text-white px-8 py-4 md:px-12 md:py-6 text-xl md:text-2xl font-bevan rounded-sm shadow-[8px_8px_0px_var(--charcoal)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[4px_4px_0px_var(--charcoal)] cursor-pointer\" data-kid=\"19\">\n                Ver Especiales\n            </button>\n        </div>\n\n        \n        <div class=\"flex-1 relative min-h-[400px] lg:min-h-auto overflow-hidden\" data-kid=\"20\">\n            <div class=\"absolute inset-0 bg-[var(--classic-crimson)] lg:[clip-path:polygon(0_0,100%_0,100%_100%,15%_100%)]\" data-kid=\"21\">\n                <img src=\"https://images.unsplash.com/photo-1767587886972-3a097117622d?auto=format&w=1200&q=80&fit=crop\" class=\"w-full h-full object-cover mix-blend-multiply grayscale brightness-75 contrast-125\" alt=\"Friendly Butcher\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n            </div>\n            \n            <div class=\"absolute bottom-10 right-10 z-20 badge bg-white p-4 rounded-full shadow-xl border-4 border-[var(--classic-crimson)] -rotate-12 flex flex-col items-center justify-center w-32 h-32 md:w-40 md:h-40\" data-kid=\"23\">\n                <span class=\"font-bevan text-[var(--classic-crimson)] text-center text-sm md:text-base leading-tight\" data-kid=\"24\">100%<br data-kid=\"25\">NATURAL</span>\n                <i class=\"ti ti-award text-2xl text-[var(--classic-crimson)] mt-1\" data-kid=\"26\"></i>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"carnes\" class=\"py-24 bg-[var(--floral-white)] overflow-hidden\" data-kid=\"27\">\n        <div class=\"container mx-auto px-6\" data-kid=\"28\">\n            <div class=\"text-center mb-24\" data-kid=\"29\">\n                <h2 class=\"font-bevan text-4xl md:text-5xl text-[var(--charcoal)] relative inline-block\" data-kid=\"30\">\n                    Cortes de la Semana\n                    <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/paint-brush.svg\" class=\"absolute -bottom-6 left-0 w-full opacity-20 h-4\" style=\"filter: brightness(0) saturate(100%) invert(17%) sepia(87%) saturate(5833%) hue-rotate(345deg) brightness(88%) contrast(92%);\" data-kid=\"31\">\n                </h2>\n            </div>\n\n            \n            <div class=\"space-y-40\" data-kid=\"32\">\n                \n                <div data-scroll class=\"flex flex-col lg:flex-row items-center gap-12 w-full lg:w-[90%] mr-auto\" data-kid=\"33\">\n                    <div class=\"w-full lg:w-1/2 relative\" data-kid=\"34\">\n                        <div class=\"absolute -inset-4 border-2 border-[var(--charcoal)] rounded-xs rotate-3\" data-kid=\"35\"></div>\n                        <div class=\"relative z-10 aspect-video overflow-hidden rounded-xs border-8 border-white shadow-xl\" data-kid=\"36\">\n                            <img src=\"https://images.pexels.com/photos/15082943/pexels-photo-15082943.jpeg?auto=compress&cs=tinysrgb&w=1000&q=80\" class=\"w-full h-full object-cover grayscale contrast-125 hover:grayscale-0 transition-all duration-1000\" alt=\"Asado Tradicional\" decoding=\"async\" loading=\"lazy\" data-kid=\"37\">\n                        </div>\n                    </div>\n                    <div class=\"w-full lg:w-1/2 relative px-4\" data-kid=\"38\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/large-paint-brush.svg\" class=\"absolute -top-16 -left-16 w-48 opacity-5 -z-10 pointer-events-none\" style=\"filter: brightness(0) saturate(100%) invert(17%) sepia(87%) saturate(5833%) hue-rotate(345deg) brightness(88%) contrast(92%);\" data-kid=\"39\">\n                        <h3 class=\"font-bevan text-4xl text-[var(--classic-crimson)] mb-6 uppercase\" data-kid=\"40\">Asado Criollo</h3>\n                        <p class=\"text-lg text-[var(--charcoal)] leading-relaxed font-medium\" data-kid=\"41\">\n                            Nuestra pieza estrella. Ternera seleccionada de las pampas, cortada con precisión quirúrgica para asegurar una cocción perfecta. El sabor de los domingos reunidos.\n                        </p>\n                        <div class=\"mt-6\" data-kid=\"42\">\n                            <span class=\"font-kalam font-bold text-lg bg-[var(--charcoal)] text-white px-4 py-1 rounded-sm -rotate-2\" data-kid=\"43\">Corte Premium</span>\n                        </div>\n                    </div>\n                </div>\n\n                \n                <div data-scroll class=\"flex flex-col lg:flex-row-reverse items-center gap-12 w-full lg:w-[90%] ml-auto\" data-kid=\"44\">\n                    <div class=\"w-full lg:w-1/2 relative\" data-kid=\"45\">\n                        <div class=\"absolute -inset-4 border-2 border-[var(--classic-crimson)] rounded-full rotate-[-2deg] opacity-20\" data-kid=\"46\"></div>\n                        <div class=\"relative z-10 aspect-video overflow-hidden rounded-full border-8 border-white shadow-xl\" data-kid=\"47\">\n                            <img src=\"https://images.pexels.com/photos/28881687/pexels-photo-28881687.jpeg?auto=compress&cs=tinysrgb&w=1000&q=80\" class=\"w-full h-full object-cover grayscale contrast-125 hover:grayscale-0 transition-all duration-1000\" alt=\"Chorizos Caseros\" decoding=\"async\" loading=\"lazy\" data-kid=\"48\">\n                        </div>\n                    </div>\n                    <div class=\"w-full lg:w-1/2 relative lg:text-right px-4\" data-kid=\"49\">\n                        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/paint-brush.svg\" class=\"absolute -top-16 -right-16 w-48 opacity-5 -z-10 rotate-180 pointer-events-none\" style=\"filter: brightness(0) saturate(100%) invert(32%) sepia(0%) saturate(1471%) hue-rotate(134deg) brightness(97%) contrast(85%);\" data-kid=\"50\">\n                        <h3 class=\"font-bevan text-4xl text-[var(--classic-crimson)] mb-6 uppercase\" data-kid=\"51\">Chorizo del Abuelo</h3>\n                        <p class=\"text-lg text-[var(--charcoal)] leading-relaxed font-medium\" data-kid=\"52\">\n                            Receta guardada bajo llave por tres generaciones. Ahumado con maderas nobles y sazonado con pimentón de la vera. Sin conservantes, puro corazón.\n                        </p>\n                    </div>\n                </div>\n\n                \n                <div data-scroll class=\"flex flex-col lg:flex-row items-center gap-12 w-full lg:w-[85%] mx-auto\" data-kid=\"53\">\n                    <div class=\"w-full lg:w-1/2 relative group\" data-kid=\"54\">\n                        <div class=\"absolute -inset-3 bg-[var(--charcoal)] rotate-1 rounded-xs group-hover:rotate-0 transition-transform\" data-kid=\"55\"></div>\n                        <div class=\"relative z-10 aspect-video overflow-hidden rounded-xs border-4 border-white shadow-lg\" data-kid=\"56\">\n                            <img src=\"https://images.pexels.com/photos/37049890/pexels-photo-37049890.jpeg?auto=compress&cs=tinysrgb&w=1000&q=80\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000\" alt=\"Costillas Especiales\" decoding=\"async\" loading=\"lazy\" data-kid=\"57\">\n                        </div>\n                    </div>\n                    <div class=\"w-full lg:w-1/2 relative px-4\" data-kid=\"58\">\n                        <h3 class=\"font-bevan text-4xl text-[var(--classic-crimson)] mb-4 uppercase\" data-kid=\"59\">Costillas de Oro</h3>\n                        <p class=\"text-lg text-[var(--charcoal)] leading-relaxed font-medium\" data-kid=\"60\">\n                            Carne que se deshace al tacto. Una selección premium para paladares exigentes que buscan redescubrir la esencia de una buena barbacoa.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <section id=\"historia\" class=\"py-24 bg-[var(--floral-white)]\" data-kid=\"61\">\n        <div class=\"container mx-auto max-w-5xl px-6 md:px-12\" data-kid=\"62\">\n            <div class=\"newspaper-container bg-white border-4 border-[var(--charcoal)] p-8 md:p-16 relative\" data-kid=\"63\">\n                \n                <div class=\"text-center border-b-2 border-[var(--charcoal)] pb-8 mb-12\" data-kid=\"64\">\n                    <p class=\"text-sm font-bold text-[var(--charcoal)] uppercase tracking-[0.3em] mb-4 italic\" data-kid=\"65\">El Diario del Buen Gusto</p>\n                    <div class=\"relative inline-block\" data-kid=\"66\">\n                        <h2 id=\"story-title\" class=\"font-bevan text-4xl md:text-7xl text-[var(--classic-crimson)] leading-none\" data-kid=\"67\">\n                            Nuestra Historia\n                        </h2>\n                        <span id=\"typewriter-cursor\" class=\"cursor-blink\" data-kid=\"68\"></span>\n                    </div>\n                    <div class=\"flex items-center justify-between mt-6 text-xs md:text-sm font-bold text-[var(--charcoal)] border-t border-[var(--charcoal)] pt-3\" data-kid=\"69\">\n                        <span data-kid=\"70\">EST. 1955</span>\n                        <span class=\"hidden md:inline\" data-kid=\"71\">VOL. LXIX ... NO. 001</span>\n                        <span data-kid=\"72\">789 PLAZA CENTRAL</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"flex flex-col lg:grid lg:grid-cols-12 gap-12\" data-kid=\"73\">\n                    \n                    <div class=\"lg:col-span-7 space-y-6\" data-kid=\"74\">\n                        <h3 class=\"font-bevan text-3xl md:text-4xl text-[var(--charcoal)] leading-tight mb-8 uppercase\" data-kid=\"75\">\n                            Un Cuchillo, Una Familia y un Siglo de Compromiso\n                        </h3>\n                        <div class=\"text-lg md:text-xl text-[var(--charcoal)] leading-relaxed text-justify relative overflow-hidden\" data-kid=\"76\">\n                            <span class=\"float-left text-8xl font-bevan text-[var(--classic-crimson)] mr-4 leading-[0.7] pt-4 mb-2\" data-kid=\"77\">T</span>\n                            <span class=\"inline-block pt-2\" data-kid=\"78\">odo comenzó con el abuelo Mateo en una pequeña esquina de la Plaza Central. Con apenas un mostrador de madera y su cuchillo favorito, se propuso una meta simple: vender solo lo que él mismo serviría en su propia mesa.</span>\n                        </div>\n                        <p class=\"text-lg md:text-xl text-[var(--charcoal)] leading-relaxed text-justify italic font-medium\" data-kid=\"79\">\n                            Esa filosofía de honestidad y calidad nos ha guiado a través de los años. No somos una cadena masiva, somos sus vecinos. Conocemos sus nombres y sabemos exactamente cómo le gusta su corte para el asado del domingo.\n                        </p>\n                        <p class=\"text-lg md:text-xl text-[var(--charcoal)] leading-relaxed text-justify\" data-kid=\"80\">\n                            Hoy, la tercera generación continúa afilando los mismos valores. La tecnología ha cambiado, pero el respeto por el animal y el cliente permanece intacto. Bienvenido a casa.\n                        </p>\n                    </div>\n\n                    \n                    <div class=\"lg:col-span-5 flex flex-col items-center\" data-kid=\"81\">\n                        <div class=\"relative w-full mb-8\" data-kid=\"82\">\n                            <div class=\"absolute -inset-2 border-2 border-[var(--classic-crimson)] translate-x-3 translate-y-3\" data-kid=\"83\"></div>\n                            <div class=\"relative z-10 border-2 border-[var(--charcoal)] overflow-hidden\" data-kid=\"84\">\n                                <img src=\"https://images.unsplash.com/photo-1612012060851-20f943c02d3d?auto=format&w=600&q=80&fit=crop\" class=\"w-full grayscale contrast-125 sepia-[0.3]\" alt=\"Vintage Meat Scale\" decoding=\"async\" loading=\"lazy\" data-kid=\"85\">\n                            </div>\n                        </div>\n                        <div class=\"bg-[var(--floral-white)] p-6 border-l-8 border-[var(--classic-crimson)] italic\" data-kid=\"86\">\n                            <p class=\"text-lg text-[var(--charcoal)] leading-relaxed\" data-kid=\"87\">\n                                \"En 'El Barrio', el peso es justo y el trato es de familia. Aquí no solo vendemos carne, alimentamos recuerdos compartidos.\"\n                            </p>\n                            <p class=\"text-right mt-4 font-bold text-[var(--classic-crimson)]\" data-kid=\"88\">— Mateo Sr.</p>\n                        </div>\n                    </div>\n                </div>\n                \n                \n                <div class=\"mt-16 pt-8 border-t-2 border-dashed border-[var(--charcoal)] text-center\" data-kid=\"89\">\n                    <p class=\"font-bevan text-lg text-[var(--charcoal)]/40 uppercase tracking-widest\" data-kid=\"90\">Servicio a Domicilio: 555-CARNE</p>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    \n    <footer id=\"contacto\" class=\"bg-[var(--charcoal)] text-white py-20 relative overflow-hidden\" data-kid=\"91\">\n        \n        <div class=\"absolute inset-0 opacity-60 pointer-events-none mix-blend-overlay\" style=\"background-image: url('https://www.transparenttextures.com/patterns/chalkboard.png');\" data-kid=\"92\"></div>\n\n        <div class=\"container mx-auto px-6 text-center relative z-10\" data-kid=\"93\">\n            \n            <div class=\"mb-12\" data-kid=\"94\">\n                <div class=\"inline-block p-5 border-2 border-dashed border-white/40 rounded-full mb-6\" data-kid=\"95\">\n                    <i class=\"ti ti-meat text-5xl text-white\" data-kid=\"96\"></i>\n                </div>\n                <h2 class=\"font-bevan text-4xl md:text-5xl mb-4 tracking-tight\" data-kid=\"97\">Carnicería El Barrio</h2>\n                <div class=\"h-1.5 w-32 bg-[var(--classic-crimson)] mx-auto mb-10\" data-kid=\"98\"></div>\n            </div>\n\n            \n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-10 max-w-4xl mx-auto mb-16\" data-kid=\"99\">\n                <div class=\"flex flex-col items-center gap-4 group p-8 border-2 border-white/10 rounded-xs hover:border-white transition-all\" data-kid=\"100\">\n                    <div class=\"w-16 h-16 rounded-full border-2 border-white/40 flex items-center justify-center group-hover:bg-white group-hover:text-[var(--charcoal)] transition-all\" data-kid=\"101\">\n                        <i class=\"ti ti-map-pin text-3xl\" data-kid=\"102\"></i>\n                    </div>\n                    <div data-kid=\"103\">\n                        <h4 class=\"font-bevan text-2xl mb-1 text-white uppercase tracking-wider\" data-kid=\"104\">Visítanos</h4>\n                        <p class=\"text-xl font-kalam text-[var(--chalk)]\" data-kid=\"105\">789 Plaza Central, Pueblo Viejo</p>\n                    </div>\n                </div>\n                <div class=\"flex flex-col items-center gap-4 group p-8 border-2 border-white/10 rounded-xs hover:border-white transition-all\" data-kid=\"106\">\n                    <div class=\"w-16 h-16 rounded-full border-2 border-white/40 flex items-center justify-center group-hover:bg-white group-hover:text-[var(--charcoal)] transition-all\" data-kid=\"107\">\n                        <i class=\"ti ti-phone text-3xl\" data-kid=\"108\"></i>\n                    </div>\n                    <div data-kid=\"109\">\n                        <h4 class=\"font-bevan text-2xl mb-1 text-white uppercase tracking-wider\" data-kid=\"110\">Llámanos</h4>\n                        <p class=\"text-xl font-kalam text-[var(--chalk)]\" data-kid=\"111\">555-CARNE (555-2276)</p>\n                    </div>\n                </div>\n            </div>\n\n            \n            <div class=\"flex justify-center gap-8 mb-16\" data-kid=\"112\">\n                <a href=\"#\" class=\"w-14 h-14 rounded-full border-2 border-white/20 flex items-center justify-center text-2xl hover:bg-white hover:text-[var(--charcoal)] transition-all\" data-kid=\"113\">\n                    <i class=\"ti ti-brand-facebook\" data-kid=\"114\"></i>\n                </a>\n                <a href=\"#\" class=\"w-14 h-14 rounded-full border-2 border-white/20 flex items-center justify-center text-2xl hover:bg-white hover:text-[var(--charcoal)] transition-all\" data-kid=\"115\">\n                    <i class=\"ti ti-brand-instagram\" data-kid=\"116\"></i>\n                </a>\n                <a href=\"#\" class=\"w-14 h-14 rounded-full border-2 border-white/20 flex items-center justify-center text-2xl hover:bg-white hover:text-[var(--charcoal)] transition-all\" data-kid=\"117\">\n                    <i class=\"ti ti-brand-whatsapp\" data-kid=\"118\"></i>\n                </a>\n            </div>\n\n            \n            <div class=\"border-t border-white/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-6 text-white/50 text-lg\" data-kid=\"119\">\n                <p data-kid=\"120\">&copy; 2024 Carnicería El Barrio. La Tradición que se Saborea.</p>\n                <div class=\"flex gap-8\" data-kid=\"121\">\n                    <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"122\">Privacidad</a>\n                    <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"123\">Términos</a>\n                </div>\n            </div>\n        </div>\n    </footer>\n</main>\n\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"124\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"125\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"126\"></script>\n<script type=\"module\" data-kid=\"127\">\n    import { animate, stagger } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n    // Initialize Locomotive Scroll\n    const locomotiveScroll = new LocomotiveScroll({\n        lenisOptions: {\n            duration: 1.2,\n            lerp: 0.1,\n            smoothWheel: true,\n        }\n    });\n\n    // Spring Pop Animation for Hero CTA\n    gsap.from(\"#hero-cta-btn\", {\n        scale: 0,\n        rotate: -15,\n        opacity: 0,\n        duration: 0.8,\n        ease: \"back.out(1.8)\",\n        delay: 0.5\n    });\n\n    // Also pop the badges\n    gsap.from(\".badge\", {\n        scale: 0,\n        rotate: 15,\n        opacity: 0,\n        duration: 1,\n        ease: \"back.out(2)\",\n        delay: 0.8\n    });\n\n    // Typewriter effect for Story Masthead\n    function initTypewriter() {\n        const title = document.getElementById('story-title');\n        if(!title) return;\n        const text = title.innerText.trim();\n        title.innerText = '';\n        \n        ScrollTrigger.create({\n            trigger: \"#historia\",\n            start: \"top 70%\",\n            onEnter: () => {\n                let i = 0;\n                function type() {\n                    if (i < text.length) {\n                        title.innerText += text.charAt(i);\n                        i++;\n                        setTimeout(type, 40);\n                    }\n                }\n                type();\n                // Blinking cursor\n                animate(\"#typewriter-cursor\", { opacity: [1, 0] }, { duration: 0.6, repeat: Infinity, direction: \"alternate\" });\n            },\n            once: true\n        });\n    }\n\n    window.addEventListener('DOMContentLoaded', initTypewriter);\n\n</script>\n",
