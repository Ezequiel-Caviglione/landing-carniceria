      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Raleway:wght@200;300;400;500;600&display=swap');\n\n  :root {\n    --color-onyx: #111111;\n    --color-jet-black: #2A3439;\n    --color-bronze: #CD7F32;\n    --progress: 0;\n  }\n\n  body {\n    font-family: 'Raleway', sans-serif;\n    background-color: var(--color-onyx);\n    color: #ffffff;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-cinzel { font-family: 'Cinzel', serif; }\n\n  /* Pattern: #glassmorphism */\n  .glass-card {\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(20px);\n    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);\n    transition: background 0.4s ease, border-color 0.4s ease;\n  }\n  .glass-card:hover {\n    background: rgba(255, 255, 255, 0.06);\n    border-color: rgba(205, 127, 50, 0.3);\n  }\n\n  .glass-nav {\n    border-bottom: 1px solid rgba(205, 127, 50, 0.3);\n    background: rgba(17, 17, 17, 0.8);\n    backdrop-filter: blur(10px);\n    z-index: 100;\n  }\n\n  /* Pattern: #hairline */\n  .hairline-bronze {\n    border-bottom: 1px solid var(--color-bronze);\n  }\n\n  /* Pattern: #dark-spotlight */\n  .spotlight-bg {\n    background: radial-gradient(ellipse at 80% 30%, rgba(205, 127, 50, 0.08) 0%, rgba(17, 17, 17, 0) 50%);\n  }\n  .spotlight-beam {\n    position: absolute;\n    top: -20%;\n    right: 10%;\n    width: 60%;\n    height: 140%;\n    background: conic-gradient(from 180deg at 50% 0%, transparent 160deg, rgba(205, 127, 50, 0.03) 180deg, transparent 200deg);\n    pointer-events: none;\n    z-index: 1;\n  }\n\n  /* Pattern: #gradient-overlay */\n  .card-gradient::after {\n    content: '';\n    position: absolute;\n    bottom: 0;\n    left: 0;\n    right: 0;\n    height: 60%;\n    background: linear-gradient(to top, var(--color-onyx), transparent);\n    pointer-events: none;\n  }\n\n  /* Pattern: #locomotive-progress-css */\n  .parallax-container {\n    --progress: 0;\n  }\n  .parallax-image {\n    transform: scale(calc(1 + var(--progress) * 0.15));\n    opacity: calc(0.6 + var(--progress) * 0.4);\n  }\n\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\">\n\n  /* Neomorph Raised adaptation for Dark Mode */\n  .btn-bronze {\n    position: relative;\n    overflow: hidden;\n    transition: color 0.4s ease;\n    isolation: isolate;\n  }\n  .btn-bronze::before {\n    content: '';\n    position: absolute;\n    top: 100%;\n    left: 0;\n    width: 100%;\n    height: 100%;\n    background: var(--color-bronze);\n    transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);\n    z-index: -1;\n  }\n  .btn-bronze:hover::before {\n    transform: translateY(-100%);\n  }\n  .btn-bronze:hover {\n    color: white;\n  }\n\n  /* Custom selection color */\n  ::selection {\n    background: var(--color-bronze);\n    color: white;\n  }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n\n    \n    <nav class=\"fixed top-0 left-0 w-full glass-nav px-8 md:px-16 py-6 flex items-center justify-between\" data-kid=\"3\">\n      <div class=\"flex items-center gap-10\" data-kid=\"4\">\n        <a href=\"#\" class=\"font-cinzel text-2xl tracking-[0.2em] font-bold text-[var(--color-bronze)]\" data-kid=\"5\">PRIME CUT</a>\n        <div class=\"hidden lg:flex gap-8 text-xs uppercase tracking-widest font-medium text-gray-400\" data-kid=\"6\">\n          <a href=\"#selection\" class=\"hover:text-white transition-colors\" data-kid=\"7\">Selection</a>\n          <a href=\"#story\" class=\"hover:text-white transition-colors\" data-kid=\"8\">Our Craft</a>\n        </div>\n      </div>\n      <div class=\"flex items-center gap-10\" data-kid=\"9\">\n        <div class=\"hidden lg:flex gap-8 text-xs uppercase tracking-widest font-medium text-gray-400\" data-kid=\"10\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"11\">Bespoke Aging</a>\n          <a href=\"#footer\" class=\"hover:text-white transition-colors\" data-kid=\"12\">Contact</a>\n        </div>\n        <a href=\"#\" class=\"btn-bronze border border-[var(--color-bronze)] px-6 py-2 text-xs uppercase tracking-widest font-bold text-[var(--color-bronze)]\" data-kid=\"13\">\n          Reserve Cut\n        </a>\n      </div>\n    </nav>\n\n    \n    <header class=\"min-h-screen spotlight-bg flex items-center px-8 md:px-16 pt-20 relative overflow-hidden\" data-kid=\"14\">\n      <div class=\"spotlight-beam\" data-kid=\"15\"></div>\n      \n      <div class=\"grid grid-cols-12 w-full items-center gap-12\" data-kid=\"16\">\n        <div class=\"col-span-12 lg:col-span-6 z-10\" id=\"hero-text\" data-kid=\"17\">\n          <span class=\"hero-item text-[var(--color-bronze)] text-xs uppercase tracking-widest mb-6 block font-medium\" data-kid=\"18\">Fine Meat Boutique</span>\n          <h1 class=\"hero-item font-cinzel text-5xl md:text-7xl lg:text-8xl leading-[0.9] mb-8\" data-kid=\"19\">\n            Exquisite Meats,<br data-kid=\"20\">\n            <span class=\"text-[var(--color-bronze)]\" data-kid=\"21\">Aged to Perfection</span>\n          </h1>\n          <p class=\"hero-item text-lg font-light text-gray-400 max-w-lg mb-12 leading-relaxed\" data-kid=\"22\">\n            Where tradition meets refinement. Each hand-selected cut is aged in Himalayan salt chambers to reach an unparalleled depth of flavor.\n          </p>\n          <div class=\"hero-item flex items-center gap-6\" data-kid=\"23\">\n            <div class=\"w-16 h-[1px] bg-[var(--color-bronze)]\" data-kid=\"24\"></div>\n            <span class=\"text-xs uppercase tracking-widest text-gray-500 font-bold\" data-kid=\"25\">Est. 1984 | Distrito Gourmet</span>\n          </div>\n        </div>\n        \n        <div class=\"col-span-12 lg:col-span-6 flex justify-end relative z-10\" data-kid=\"26\">\n          \n          <div class=\"relative w-full aspect-[4/5] max-w-xl group overflow-hidden rounded-sm glass-card\" id=\"hero-img-container\" data-kid=\"27\">\n            <img src=\"https://images.pexels.com/photos/109395/pexels-photo-109395.jpeg?auto=compress&cs=tinysrgb&w=1400&q=80\" alt=\"Gourmet steak on slate\" class=\"w-full h-full object-cover grayscale-[0.4] hover:grayscale-0 hover:transition-all hover:duration-700\" id=\"hero-image\" decoding=\"async\" loading=\"lazy\" data-kid=\"28\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-onyx)]/80 via-transparent to-transparent\" data-kid=\"29\"></div>\n          </div>\n        </div>\n      </div>\n    </header>\n\n    \n    <section id=\"selection\" class=\"py-32 px-8 md:px-16 bg-[var(--color-onyx)] relative overflow-hidden\" data-kid=\"30\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"31\">\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-24 gap-8\" data-kid=\"32\">\n          <div data-kid=\"33\">\n            <span class=\"text-[var(--color-bronze)] text-xs uppercase tracking-widest mb-4 block\" data-kid=\"34\">Our Curated</span>\n            <h2 class=\"font-cinzel text-4xl md:text-5xl\" data-kid=\"35\">The Master's Selection</h2>\n          </div>\n          <p class=\"text-gray-400 max-w-xs text-sm font-light leading-relaxed\" data-kid=\"36\">\n            Explore our signature cuts, ranging from rare wagyu to locally sourced grass-fed heritage breeds.\n          </p>\n        </div>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"37\">\n          \n          <div class=\"flex flex-col gap-12\" data-kid=\"38\">\n            \n            <div class=\"meat-card group glass-card relative overflow-hidden aspect-[4/5]\" data-kid=\"39\">\n              <img src=\"https://images.pexels.com/photos/34434635/pexels-photo-34434635.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Black Angus Filet\" class=\"w-full h-full object-cover hover:transition-transform hover:duration-1000 group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"40\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-onyx)]/90 via-transparent to-transparent flex flex-col justify-end p-10\" data-kid=\"41\">\n                <span class=\"text-[var(--color-bronze)] text-xs uppercase tracking-widest mb-3\" data-kid=\"42\">Prime Nebraska</span>\n                <h3 class=\"font-cinzel text-3xl mb-2\" data-kid=\"43\">Black Angus Filet</h3>\n                <p class=\"text-sm font-light text-gray-400\" data-kid=\"44\">Corn-fed, 28 days aged for ultimate tenderness.</p>\n              </div>\n            </div>\n            \n            \n            <div class=\"meat-card group glass-card relative overflow-hidden aspect-video\" data-kid=\"45\">\n              <img src=\"https://images.pexels.com/photos/12884547/pexels-photo-12884547.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Reserve Selection\" class=\"w-full h-full object-cover hover:transition-transform hover:duration-1000 group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"46\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-onyx)]/90 via-transparent to-transparent flex flex-col justify-end p-8\" data-kid=\"47\">\n                <h3 class=\"font-cinzel text-2xl\" data-kid=\"48\">The Reserve Selection</h3>\n                <p class=\"text-xs font-light text-gray-500 uppercase tracking-widest mt-2\" data-kid=\"49\">Rotating Seasonal Cuts</p>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"flex flex-col gap-12 md:mt-12\" data-kid=\"50\">\n            \n            <div class=\"meat-card group glass-card relative overflow-hidden aspect-video\" data-kid=\"51\">\n              <img src=\"https://images.unsplash.com/photo-1460122109654-7e46ab4fc9b9?auto=format&w=800&q=80&fit=crop\" alt=\"Artisan Charcuterie\" class=\"w-full h-full object-cover hover:transition-transform hover:duration-1000 group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"52\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-onyx)]/90 via-transparent to-transparent flex flex-col justify-end p-8\" data-kid=\"53\">\n                <h3 class=\"font-cinzel text-2xl\" data-kid=\"54\">Artisan Charcuterie</h3>\n                <p class=\"text-xs font-light text-gray-500 uppercase tracking-widest mt-2\" data-kid=\"55\">House-cured Specialty</p>\n              </div>\n            </div>\n            \n            \n            <div class=\"meat-card group glass-card relative overflow-hidden aspect-[4/5]\" data-kid=\"56\">\n              <img src=\"https://images.pexels.com/photos/36319691/pexels-photo-36319691.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"Bone-In Ribeye\" class=\"w-full h-full object-cover hover:transition-transform hover:duration-1000 group-hover:scale-105\" decoding=\"async\" loading=\"lazy\" data-kid=\"57\">\n              <div class=\"absolute inset-0 bg-gradient-to-t from-[var(--color-onyx)]/90 via-transparent to-transparent flex flex-col justify-end p-10\" data-kid=\"58\">\n                <span class=\"text-[var(--color-bronze)] text-xs uppercase tracking-widest mb-3\" data-kid=\"59\">Dry-Aged 45 Days</span>\n                <h3 class=\"font-cinzel text-3xl mb-2\" data-kid=\"60\">Heritage Ribeye</h3>\n                <p class=\"text-sm font-light text-gray-400\" data-kid=\"61\">Grass-fed, sourced from sustainable Irish pastures.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"story\" class=\"relative min-h-screen flex items-center justify-center py-40 overflow-hidden parallax-container\" data-scroll data-scroll-css-progress data-kid=\"62\">\n      \n      <div class=\"absolute inset-0 z-0\" data-kid=\"63\">\n        <img src=\"https://images.unsplash.com/photo-1481872385041-9649028b9add?auto=format&w=1600&q=80&fit=crop\" alt=\"Butcher sharpening knife\" class=\"w-full h-full object-cover grayscale brightness-[0.2] parallax-image\" decoding=\"async\" loading=\"lazy\" data-kid=\"64\">\n        <div class=\"absolute inset-0 bg-gradient-to-b from-[var(--color-onyx)] via-transparent to-[var(--color-onyx)]\" data-kid=\"65\"></div>\n      </div>\n\n      <div class=\"relative z-10 max-w-5xl px-8 text-center\" id=\"story-content\" data-kid=\"66\">\n        <span class=\"text-[var(--color-bronze)] text-xs uppercase tracking-widest mb-12 block font-medium\" data-kid=\"67\">The Founder's Philosophy</span>\n        <blockquote class=\"font-cinzel italic text-4xl md:text-6xl lg:text-7xl leading-[1.2] mb-16 text-white/90\" data-kid=\"68\">\n          “The art of butchery is not just about the cut, but the respect for the beast and the patience of the age.”\n        </blockquote>\n        <div class=\"flex flex-col items-center gap-2\" data-kid=\"69\">\n          <p class=\"font-cinzel text-xl tracking-widest text-[var(--color-bronze)]\" data-kid=\"70\">JULIAN DE ORO</p>\n          <p class=\"text-xs uppercase tracking-widest text-gray-500 font-bold\" data-kid=\"71\">Master Artisan Butcher</p>\n        </div>\n      </div>\n      \n      <div class=\"absolute bottom-16 right-16 font-cinzel text-gray-600 text-sm tracking-widest hidden md:block\" data-kid=\"72\">\n        EST. MCMXXXIV\n      </div>\n    </section>\n\n    \n    <footer id=\"footer\" class=\"bg-[var(--color-onyx)] pt-40 pb-12 px-8 md:px-16 border-t border-white/5 relative overflow-hidden\" data-kid=\"73\">\n      <div class=\"max-w-7xl mx-auto\" data-kid=\"74\">\n        <div class=\"flex flex-col items-center mb-24\" data-kid=\"75\">\n          <h2 class=\"font-cinzel text-4xl md:text-5xl tracking-[0.4em] text-[var(--color-bronze)] mb-4\" data-kid=\"76\">PRIME CUT</h2>\n          <div class=\"w-12 h-[1px] bg-white/10\" data-kid=\"77\"></div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-8 mb-32 text-center md:text-left\" data-kid=\"78\">\n          <div class=\"footer-item\" data-kid=\"79\">\n            <h4 class=\"text-xs uppercase tracking-widest font-bold text-gray-600 mb-6\" data-kid=\"80\">The Atelier</h4>\n            <p class=\"text-xl font-light text-gray-300 leading-relaxed\" data-kid=\"81\">\n              456 Avenida de Oro<br data-kid=\"82\">\n              Distrito Gourmet, 90210\n            </p>\n          </div>\n          <div class=\"footer-item\" data-kid=\"83\">\n            <h4 class=\"text-xs uppercase tracking-widest font-bold text-gray-600 mb-6\" data-kid=\"84\">Concierge</h4>\n            <p class=\"text-xl font-light text-gray-300 leading-relaxed\" data-kid=\"85\">\n              +1 800-987-6543<br data-kid=\"86\">\n              concierge@primecut.com\n            </p>\n          </div>\n          <div class=\"footer-item\" data-kid=\"87\">\n            <h4 class=\"text-xs uppercase tracking-widest font-bold text-gray-600 mb-6\" data-kid=\"88\">Atelier Hours</h4>\n            <p class=\"text-xl font-light text-gray-300 leading-relaxed\" data-kid=\"89\">\n              Tue — Sat: 10:00 - 19:00<br data-kid=\"90\">\n              Sun: Private Viewings\n            </p>\n          </div>\n        </div>\n\n        <div class=\"w-full h-[1px] bg-white/5 mb-10\" data-kid=\"91\"></div>\n        \n        <div class=\"flex flex-col md:flex-row justify-between items-center gap-8\" data-kid=\"92\">\n          <div class=\"flex gap-10 text-xs uppercase tracking-widest font-medium text-gray-500\" data-kid=\"93\">\n            <a href=\"#\" class=\"hover:text-[var(--color-bronze)] transition-colors\" data-kid=\"94\">Instagram</a>\n            <a href=\"#\" class=\"hover:text-[var(--color-bronze)] transition-colors\" data-kid=\"95\">Journal</a>\n            <a href=\"#\" class=\"hover:text-[var(--color-bronze)] transition-colors\" data-kid=\"96\">Inquiry</a>\n          </div>\n          <p class=\"text-xs uppercase tracking-widest text-gray-600 font-medium\" data-kid=\"97\">\n            © 2024 Prime Cut Luxury Butchery. Crafted for the Discerning Palette.\n          </p>\n        </div>\n      </div>\n    </footer>\n\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"98\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"99\"></script>\n<script type=\"module\" data-kid=\"100\">\n  import Lenis from \"https://esm.sh/lenis@1\"\n  \n  // Initialize Lenis\n  const lenis = new Lenis({\n    duration: 1.2,\n    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n    smoothWheel: true,\n  });\n\n  function raf(time) {\n    lenis.raf(time);\n    requestAnimationFrame(raf);\n  }\n  requestAnimationFrame(raf);\n\n  // Sync ScrollTrigger with Lenis\n  lenis.on('scroll', ScrollTrigger.update);\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000);\n  });\n  gsap.ticker.lagSmoothing(0);\n\n  // GSAP Animations\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Pattern: #gsap-blur-in (Hero Entrance)\n  gsap.from(\"#hero-image\", {\n    autoAlpha: 0,\n    filter: \"blur(12px)\",\n    scale: 1.1,\n    duration: 1.5,\n    ease: \"power3.out\",\n    delay: 0.5\n  });\n\n  gsap.from(\".hero-item\", {\n    y: 40,\n    opacity: 0,\n    duration: 1,\n    stagger: 0.2,\n    ease: \"power3.out\",\n    delay: 0.2\n  });\n\n  // Pattern: #gsap-scroll-batch (Masonry Cards)\n  ScrollTrigger.batch(\".meat-card\", {\n    start: \"top 85%\",\n    onEnter: (elements) => {\n      gsap.to(elements, {\n        opacity: 1,\n        y: 0,\n        duration: 0.8,\n        stagger: 0.15,\n        ease: \"power2.out\",\n        overwrite: true\n      });\n    },\n    onLeaveBack: (elements) => {\n      gsap.set(elements, { opacity: 0, y: 50 });\n    }\n  });\n  // Initial state for batch\n  gsap.set(\".meat-card\", { opacity: 0, y: 50 });\n\n  // Pattern: #locomotive-progress-css (Story Parallax)\n  const storySection = document.querySelector('.parallax-container');\n  ScrollTrigger.create({\n    trigger: storySection,\n    start: \"top bottom\",\n    end: \"bottom top\",\n    onUpdate: (self) => {\n      storySection.style.setProperty('--progress', self.progress);\n    }\n  });\n\n  // Story Content Reveal\n  gsap.from(\"#story-content\", {\n    scrollTrigger: {\n      trigger: \"#story\",\n      start: \"top 60%\",\n    },\n    y: 60,\n    opacity: 0,\n    duration: 1.2,\n    ease: \"power3.out\"\n  });\n\n  // Footer Items Stagger\n  gsap.from(\".footer-item\", {\n    scrollTrigger: {\n      trigger: \"footer\",\n      start: \"top 80%\",\n    },\n    opacity: 0,\n    y: 30,\n    duration: 1,\n    stagger: 0.2,\n    ease: \"power2.out\"\n  });\n\n</script>\n",
