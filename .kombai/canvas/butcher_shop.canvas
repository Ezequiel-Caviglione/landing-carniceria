      "html": "<div id=\"smooth-wrapper\" class=\"bg-[#FDFBF7] text-[#704214] font-['DM_Sans'] selection:bg-[#960018] selection:text-[#FDFBF7]\" data-kid=\"0\">\n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,ital,wght@9..144,0,400;0,700;1,400;1,700&family=DM+Sans:wght@400;500;700&display=swap');\n\n    :root {\n      --cream: #FDFBF7;\n      --walnut: #704214;\n      --crimson: #960018;\n    }\n\n    .font-fraunces { font-family: 'Fraunces', serif; }\n    \n    [data-scroll].reveal-cell {\n      opacity: 0;\n      transform: translateY(30px);\n      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);\n      transition-delay: calc(var(--i) * 100ms);\n    }\n    [data-scroll].reveal-cell.is-inview {\n      opacity: 1;\n      transform: translateY(0);\n    }\n\n    ::-webkit-scrollbar { width: 8px; }\n    ::-webkit-scrollbar-track { background: var(--cream); }\n    ::-webkit-scrollbar-thumb { background: var(--walnut); }\n    ::-webkit-scrollbar-thumb:hover { background: var(--crimson); }\n\n    .has-scroll-smooth [data-scroll-container] {\n      min-height: 100vh;\n    }\n  </style>\n\n  \n  <header class=\"fixed top-0 left-0 w-full z-50 bg-[#FDFBF7]/90 backdrop-blur-md border-b border-[#704214]/10 navbar-item\" data-kid=\"2\">\n    <nav class=\"flex items-center justify-between px-8 lg:px-16 py-5 max-w-[1920px] mx-auto\" data-kid=\"3\">\n      <div class=\"flex gap-10 text-xs font-bold tracking-[0.2em] uppercase\" data-kid=\"4\">\n        <a href=\"#\" class=\"hover:text-[#960018] transition-colors\" data-kid=\"5\">La Tienda</a>\n        <a href=\"#\" class=\"hover:text-[#960018] transition-colors\" data-kid=\"6\">Cortes</a>\n        <a href=\"#\" class=\"hover:text-[#960018] transition-colors\" data-kid=\"7\">Nosotros</a>\n      </div>\n      <div class=\"absolute left-1/2 -translate-x-1/2 flex flex-col items-center\" data-kid=\"8\">\n        <span class=\"text-[0.55rem] font-bold tracking-[0.4em] uppercase text-[#704214]/40 mb-0.5\" data-kid=\"9\">Artesanal</span>\n        <h1 class=\"font-fraunces text-2xl lg:text-3xl font-bold tracking-tight text-[#960018]\" data-kid=\"10\">LA CARNICERÍA</h1>\n      </div>\n      <div class=\"flex items-center gap-8\" data-kid=\"11\">\n        <span class=\"hidden md:block text-xs font-bold tracking-widest\" data-kid=\"12\">(555) 123-4567</span>\n        <button class=\"bg-[#960018] text-white px-8 py-3 rounded-full text-xs font-bold tracking-widest hover:bg-[#704214] transition-colors cursor-pointer\" data-kid=\"13\">\n          PEDIR AHORA\n        </button>\n      </div>\n    </nav>\n  </header>\n\n  <main data-scroll-container data-kid=\"14\">\n    \n    <section class=\"relative min-h-screen flex items-center overflow-hidden\" id=\"hero\" data-kid=\"15\">\n      <div class=\"absolute inset-0 z-0\" data-kid=\"16\">\n        <img id=\"hero-image\" src=\"https://images.unsplash.com/photo-1690618513975-324617013892?crop=entropy&cs=srgb&fm=jpg&q=85&auto=format&w=2000\" alt=\"Premium raw steak with rosemary\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"17\">\n        <div class=\"absolute inset-0 bg-gradient-to-r from-[#FDFBF7] via-[#FDFBF7]/85 to-transparent\" data-kid=\"18\"></div>\n      </div>\n\n      <div class=\"relative z-10 px-8 lg:px-24 py-32 max-w-4xl\" data-kid=\"19\">\n        <span class=\"hero-anim-item text-[#960018] font-bold tracking-[0.3em] uppercase text-xs mb-8 block\" data-kid=\"20\">Est. 1924 • Artisan Block</span>\n        <h2 class=\"hero-anim-item font-fraunces text-6xl xl:text-8xl font-bold leading-none mb-10 text-[#704214]\" data-kid=\"21\">\n          Cortes Premium, <br data-kid=\"22\"><span class=\"italic font-light\" data-kid=\"23\">Tradición Diaria</span>\n        </h2>\n        <p class=\"hero-anim-item text-xl text-[#704214]/80 max-w-lg mb-12 leading-relaxed\" data-kid=\"24\">\n          Tres generaciones de maestros carniceros seleccionando personalmente cada pieza de ganaderías locales sostenibles.\n        </p>\n        <div class=\"hero-anim-item flex flex-wrap gap-6\" data-kid=\"25\">\n          <button class=\"bg-[#960018] text-white px-12 py-5 font-bold text-sm tracking-widest uppercase hover:bg-[#704214] transition-colors group cursor-pointer shadow-lg\" data-kid=\"26\">\n            Explorar el Mostrador\n            <i class=\"fa-solid fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform\" data-kid=\"27\"></i>\n          </button>\n          <button class=\"bg-[#FDFBF7] border border-[#704214]/20 px-12 py-5 font-bold text-sm tracking-widest uppercase hover:bg-[#704214] hover:text-[#FDFBF7] transition-all cursor-pointer\" data-kid=\"28\">\n            Nuestra Historia\n          </button>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-[#FDFBF7] px-8 lg:px-16\" id=\"featured\" data-kid=\"29\">\n      <div class=\"max-w-[1600px] mx-auto\" data-kid=\"30\">\n        <div class=\"flex flex-col lg:flex-row justify-between items-start lg:items-end mb-20 gap-8\" data-kid=\"31\">\n          <div data-scroll data-scroll-speed=\"0.1\" data-kid=\"32\">\n            <span class=\"text-[#960018] font-bold tracking-[0.2em] uppercase text-xs mb-4 block\" data-kid=\"33\">Lo mejor de la semana</span>\n            <h2 class=\"font-fraunces text-5xl lg:text-7xl font-bold text-[#704214]\" data-kid=\"34\">Selección del Maestro</h2>\n          </div>\n          <p class=\"max-w-md text-[#704214]/60 text-lg leading-relaxed\" data-kid=\"35\">\n            Piezas exclusivas maduradas en cámara y cortes de autor preparados por nuestro equipo de expertos para los paladares más exigentes.\n          </p>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 h-auto lg:h-[700px]\" data-kid=\"36\">\n          \n          <div class=\"lg:col-span-8 lg:row-span-2 relative group overflow-hidden rounded-3xl bg-[#704214]/5 flex flex-col justify-end p-8 lg:p-14 reveal-cell\" style=\"--i: 0\" data-scroll data-kid=\"37\">\n            <img src=\"https://images.pexels.com/photos/31406832/pexels-photo-31406832.jpeg?auto=compress&cs=tinysrgb&w=1400&q=80\" alt=\"A5 Wagyu Ribeye\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"38\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#000]/95 via-[#000]/40 to-transparent\" data-kid=\"39\"></div>\n            <div class=\"relative z-10 text-white\" data-kid=\"40\">\n              <span class=\"bg-[#960018] px-5 py-1.5 rounded-full text-[0.65rem] font-bold uppercase tracking-[0.2em] mb-6 inline-block\" data-kid=\"41\">Edición Limitada</span>\n              <h3 class=\"font-fraunces text-4xl lg:text-5xl font-bold mb-2\" data-kid=\"42\">A5 Wagyu Ribeye</h3>\n              <p class=\"font-fraunces text-xl italic text-white/70 mb-6\" data-kid=\"43\">Marmolado Excepcional • Prefectura de Miyazaki</p>\n              <p class=\"text-white/80 max-w-xl text-lg mb-8 leading-relaxed\" data-kid=\"44\">\n                Importado directamente de Japón. Una experiencia sensorial única con un sabor a mantequilla insuperable.\n              </p>\n              <div class=\"flex items-center gap-8\" data-kid=\"45\">\n                <div class=\"text-3xl font-fraunces font-bold\" data-kid=\"46\">$185.00 <span class=\"text-sm font-sans font-medium text-white/50\" data-kid=\"47\">/ kg</span></div>\n                <button class=\"bg-white text-[#960018] px-10 py-4 rounded-full font-bold text-sm tracking-widest uppercase hover:bg-[#960018] hover:text-white transition-colors cursor-pointer\" data-kid=\"48\">Reservar Ahora</button>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"lg:col-span-4 lg:row-span-1 relative group overflow-hidden rounded-3xl bg-[#704214]/5 p-10 flex flex-col justify-end reveal-cell\" style=\"--i: 1\" data-scroll data-kid=\"49\">\n            <img src=\"https://images.unsplash.com/photo-1588347818036-558601350947?crop=entropy&cs=srgb&fm=jpg&q=85&auto=format&w=800\" alt=\"Ribeye Dry-Aged\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"50\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#000]/90 to-transparent\" data-kid=\"51\"></div>\n            <div class=\"relative z-10 text-white\" data-kid=\"52\">\n              <h4 class=\"font-fraunces text-3xl font-bold mb-2\" data-kid=\"53\">Ribeye Dry-Aged</h4>\n              <p class=\"text-sm text-white/70 mb-6 tracking-widest uppercase\" data-kid=\"54\">45 Días de Maduración</p>\n              <a href=\"#\" class=\"text-sm font-bold tracking-[0.2em] uppercase border-b border-white/30 pb-1 hover:border-white transition-colors inline-block\" data-kid=\"55\">Detalles del Corte</a>\n            </div>\n          </div>\n\n          \n          <div class=\"lg:col-span-4 lg:row-span-1 relative group overflow-hidden rounded-3xl bg-[#704214]/5 p-10 flex flex-col justify-end reveal-cell\" style=\"--i: 2\" data-scroll data-kid=\"56\">\n            <img src=\"https://images.unsplash.com/photo-1588347752716-d4b658ec0278?crop=entropy&cs=srgb&fm=jpg&q=85&auto=format&w=800\" alt=\"Tomahawk\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110\" decoding=\"async\" loading=\"lazy\" data-kid=\"57\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-[#000]/90 to-transparent\" data-kid=\"58\"></div>\n            <div class=\"relative z-10 text-white\" data-kid=\"59\">\n              <h4 class=\"font-fraunces text-3xl font-bold mb-2\" data-kid=\"60\">Tomahawk Steak</h4>\n              <p class=\"text-sm text-white/70 mb-6 tracking-widest uppercase\" data-kid=\"61\">Ideal para la Brasa</p>\n              <a href=\"#\" class=\"text-sm font-bold tracking-[0.2em] uppercase border-b border-white/30 pb-1 hover:border-white transition-colors inline-block\" data-kid=\"62\">Reservar Corte</a>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 lg:py-48 bg-[#704214] text-[#FDFBF7] relative overflow-hidden\" id=\"story\" data-kid=\"63\">\n      <div class=\"absolute top-0 right-0 w-1/3 h-full bg-[#960018]/5 pointer-events-none\" data-kid=\"64\"></div>\n      \n      <div class=\"max-w-[800px] mx-auto px-8 relative z-20\" data-kid=\"65\">\n        <div class=\"prose prose-invert prose-[#FDFBF7] max-w-none\" data-kid=\"66\">\n          <p class=\"text-xl lg:text-2xl leading-[1.6] mb-20 font-light opacity-90\" data-scroll data-scroll-speed=\"0.2\" data-kid=\"67\">\n            Nuestra historia comenzó en 1924, cuando el bisabuelo Antonio abrió las puertas de un pequeño local en la Calle Principal. Solo existía el respeto por el animal y el conocimiento profundo de cada fibra.\n          </p>\n\n          \n          <div class=\"quote-parallax-wrapper relative\" data-scroll data-scroll-speed=\"0.3\" data-kid=\"68\">\n            <blockquote class=\"quote-entrance relative -mx-8 lg:-mx-24 my-24 py-16 px-12 border-y border-[#FDFBF7]/10 flex flex-col items-center text-center group bg-white/5 backdrop-blur-md rounded-lg\" data-kid=\"69\">\n              <i class=\"fa-solid fa-quote-left text-5xl text-[#960018]/50 absolute -top-6 left-1/2 -translate-x-1/2\" data-kid=\"70\"></i>\n              <p class=\"font-fraunces text-2xl lg:text-4xl font-bold leading-tight max-w-3xl italic text-[#FDFBF7]\" data-kid=\"71\">\n                La carne no es una mercancía, es una artesanía que requiere paciencia y respeto absoluto.\n              </p>\n              <div class=\"mt-8 flex flex-col items-center\" data-kid=\"72\">\n                <span class=\"w-12 h-[1px] bg-[#960018] mb-4\" data-kid=\"73\"></span>\n                <cite class=\"font-bold tracking-[0.3em] uppercase text-xs not-italic text-[#960018]\" data-kid=\"74\">Maestro Carnicero Antonio (III)</cite>\n              </div>\n            </blockquote>\n          </div>\n\n          <p class=\"text-xl lg:text-2xl leading-[1.6] font-light opacity-90\" data-scroll data-scroll-speed=\"0.2\" data-kid=\"75\">\n            Hoy, casi un siglo después, trabajamos exclusivamente con granjas que comparten nuestra visión de bienestar animal y sostenibilidad. Un animal bien cuidado es la única forma de obtener una pieza extraordinaria.\n          </p>\n        </div>\n      </div>\n\n      \n      <div class=\"hidden xl:block absolute right-[-5%] top-1/4 w-[450px] h-[650px] overflow-hidden rounded-3xl shadow-2xl rotate-6 z-10 opacity-50\" data-scroll data-scroll-speed=\"0.8\" data-kid=\"76\">\n        <img src=\"https://images.unsplash.com/photo-1580117287402-5e41b890e6b6?crop=entropy&cs=srgb&fm=jpg&q=85&auto=format&w=800\" alt=\"Vintage butcher shop\" class=\"w-full h-full object-cover grayscale sepia contrast-125\" decoding=\"async\" loading=\"lazy\" data-kid=\"77\">\n        <div class=\"absolute inset-0 bg-[#704214]/30 mix-blend-multiply\" data-kid=\"78\"></div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-24 bg-[#FDFBF7] px-8 border-t border-[#704214]/10\" data-kid=\"79\">\n      <div class=\"max-w-6xl mx-auto bg-[#704214] rounded-[40px] p-12 lg:p-20 relative overflow-hidden text-[#FDFBF7] text-center\" data-kid=\"80\">\n        <div class=\"absolute inset-0 opacity-10 pointer-events-none bg-[url('https://www.transparenttextures.com/patterns/wood-pattern-1.png')]\" data-kid=\"81\"></div>\n        <div class=\"relative z-10 max-w-2xl mx-auto\" data-kid=\"82\">\n          <span class=\"text-[#960018] font-bold tracking-[0.3em] uppercase text-xs mb-6 block\" data-kid=\"83\">El Gremio</span>\n          <h2 class=\"font-fraunces text-4xl lg:text-5xl font-bold mb-6\" data-kid=\"84\">Únete al Gremio de la Carne</h2>\n          <p class=\"text-lg opacity-80 mb-12\" data-kid=\"85\">Recibe cortes exclusivos, consejos de maduración y acceso prioritario a piezas de edición limitada.</p>\n          <form class=\"flex flex-col md:flex-row gap-4\" data-kid=\"86\">\n            <input type=\"email\" placeholder=\"Tu correo electrónico\" class=\"flex-1 bg-white/10 border border-white/20 px-8 py-5 rounded-full outline-hidden focus:ring-2 focus:ring-[#960018] transition-all text-white placeholder:text-white/50\" data-kid=\"87\">\n            <button class=\"bg-[#960018] text-white px-12 py-5 rounded-full font-bold text-sm tracking-widest uppercase hover:bg-white hover:text-[#704214] transition-all shadow-xl cursor-pointer\" data-kid=\"88\">\n              SUSCRIBIRSE\n            </button>\n          </form>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"bg-[#FDFBF7] pt-16 pb-12 overflow-hidden\" data-kid=\"89\">\n      <div class=\"max-w-[1600px] mx-auto px-8 lg:px-16\" data-kid=\"90\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-16 mb-24\" data-kid=\"91\">\n          <div class=\"lg:col-span-4\" data-kid=\"92\">\n            <h3 class=\"font-fraunces text-3xl font-bold text-[#960018] mb-8\" data-kid=\"93\">LA CARNICERÍA</h3>\n            <p class=\"text-[#704214]/60 text-lg leading-relaxed mb-10 max-w-sm\" data-kid=\"94\">\n              Honrando el arte de la carnicería tradicional desde 1924. Calidad superior y cortes de autor.\n            </p>\n            <div class=\"flex gap-4\" data-kid=\"95\">\n              <a href=\"#\" class=\"w-12 h-12 rounded-full border-2 border-[#704214]/50 flex items-center justify-center hover:bg-[#704214] hover:text-[#FDFBF7] transition-all\" data-kid=\"96\">\n                <i class=\"fa-brands fa-instagram\" data-kid=\"97\"></i>\n              </a>\n              <a href=\"#\" class=\"w-12 h-12 rounded-full border-2 border-[#704214]/50 flex items-center justify-center hover:bg-[#704214] hover:text-[#FDFBF7] transition-all\" data-kid=\"98\">\n                <i class=\"fa-brands fa-facebook-f\" data-kid=\"99\"></i>\n              </a>\n              <a href=\"#\" class=\"w-12 h-12 rounded-full border-2 border-[#704214]/50 flex items-center justify-center hover:bg-[#704214] hover:text-[#FDFBF7] transition-all\" data-kid=\"100\">\n                <i class=\"fa-brands fa-x-twitter\" data-kid=\"101\"></i>\n              </a>\n            </div>\n          </div>\n\n          <div class=\"lg:col-span-2\" data-kid=\"102\">\n            <h4 class=\"font-bold tracking-widest uppercase text-xs mb-8 text-[#704214]\" data-kid=\"103\">Explorar</h4>\n            <ul class=\"space-y-4 text-sm font-medium opacity-70\" data-kid=\"104\">\n              <li data-kid=\"105\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"106\">Nuestros Cortes</a></li>\n              <li data-kid=\"107\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"108\">Suscripciones</a></li>\n              <li data-kid=\"109\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"110\">Vinos</a></li>\n              <li data-kid=\"111\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"112\">Guía de Cocción</a></li>\n            </ul>\n          </div>\n\n          <div class=\"lg:col-span-2\" data-kid=\"113\">\n            <h4 class=\"font-bold tracking-widest uppercase text-xs mb-8 text-[#704214]\" data-kid=\"114\">Compañía</h4>\n            <ul class=\"space-y-4 text-sm font-medium opacity-70\" data-kid=\"115\">\n              <li data-kid=\"116\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"117\">Nosotros</a></li>\n              <li data-kid=\"118\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"119\">Granjas</a></li>\n              <li data-kid=\"120\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"121\">Sostenibilidad</a></li>\n              <li data-kid=\"122\"><a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"123\">Contacto</a></li>\n            </ul>\n          </div>\n\n          <div class=\"lg:col-span-4 bg-[#704214] text-[#FDFBF7] p-10 rounded-3xl shadow-xl relative overflow-hidden group\" data-kid=\"124\">\n            <div class=\"absolute top-0 right-0 w-32 h-32 bg-[#960018] -mr-16 -mt-16 rounded-full group-hover:scale-125 transition-transform duration-700\" data-kid=\"125\"></div>\n            <h4 class=\"font-bold tracking-widest uppercase text-xs mb-8 opacity-60\" data-kid=\"126\">Visítanos</h4>\n            <div class=\"space-y-6 relative z-10\" data-kid=\"127\">\n              <div data-kid=\"128\">\n                <p class=\"font-fraunces text-2xl font-bold mb-1 italic\" data-kid=\"129\">123 Calle Principal</p>\n                <p class=\"text-sm opacity-70\" data-kid=\"130\">Ciudad, 45678</p>\n              </div>\n              <div class=\"pt-6 border-t border-white/10\" data-kid=\"131\">\n                <p class=\"text-sm font-bold uppercase tracking-widest mb-3\" data-kid=\"132\">Horario</p>\n                <div class=\"flex justify-between text-sm opacity-70\" data-kid=\"133\">\n                  <span data-kid=\"134\">Lun - Sáb</span>\n                  <span data-kid=\"135\">8:00 - 19:00</span>\n                </div>\n                <div class=\"flex justify-between text-sm opacity-70 mt-1\" data-kid=\"136\">\n                  <span data-kid=\"137\">Domingo</span>\n                  <span data-kid=\"138\">9:00 - 14:00</span>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"flex flex-col md:flex-row items-center justify-between py-12 gap-6 text-xs font-bold tracking-widest uppercase opacity-50\" data-kid=\"139\">\n          <p data-kid=\"140\">© 2024 La Carnicería Artesanal. Todos los derechos reservados.</p>\n          <div class=\"flex gap-8\" data-kid=\"141\">\n            <a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"142\">Privacidad</a>\n            <a href=\"#\" class=\"hover:text-[#960018]\" data-kid=\"143\">Cookies</a>\n          </div>\n        </div>\n      </div>\n    </footer>\n  </main>\n\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"144\"></script>\n  <script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"145\"></script>\n  <script type=\"module\" data-kid=\"146\">\n    import Lenis from \"https://esm.sh/lenis@1\"\n    \n    const lenis = new Lenis({\n      duration: 1.2,\n      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),\n      smoothWheel: true\n    });\n\n    function raf(time) {\n      lenis.raf(time);\n      requestAnimationFrame(raf);\n    }\n    requestAnimationFrame(raf);\n\n    lenis.on('scroll', ScrollTrigger.update);\n    gsap.ticker.add((time) => {\n      lenis.raf(time * 1000);\n    });\n    gsap.ticker.lagSmoothing(0);\n\n    document.addEventListener('DOMContentLoaded', () => {\n      gsap.from('.navbar-item', {\n        y: -100,\n        opacity: 0,\n        duration: 1,\n        ease: 'power4.out',\n        delay: 0.5\n      });\n\n      gsap.from('.hero-anim-item', {\n        y: 40,\n        opacity: 0,\n        duration: 1.2,\n        stagger: 0.15,\n        ease: 'power4.out',\n        delay: 0.2\n      });\n\n      gsap.fromTo('#hero-image', \n        { scale: 1.2 }, \n        { scale: 1, duration: 2.5, ease: 'expo.out' }\n      );\n\n      const reveals = document.querySelectorAll('.reveal-cell');\n      reveals.forEach((el) => {\n        ScrollTrigger.create({\n          trigger: el,\n          start: 'top 85%',\n          onEnter: () => el.classList.add('is-inview')\n        });\n      });\n\n      ScrollTrigger.create({\n        trigger: '.quote-entrance',\n        start: 'top 80%',\n        onEnter: () => {\n          gsap.from('.quote-entrance', {\n            opacity: 0,\n            scale: 0.95,\n            duration: 1.5,\n            ease: 'power3.out'\n          });\n        }\n      });\n    });\n\n    gsap.to('[data-scroll-speed]', {\n      y: (i, target) => {\n        const speed = parseFloat(target.getAttribute('data-scroll-speed'));\n        return -speed * 150;\n      },\n      ease: \"none\",\n      scrollTrigger: {\n        trigger: 'main',\n        start: \"top top\",\n        end: \"bottom bottom\",\n        scrub: true\n      }\n    });\n  </script>\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/lenis@1/dist/lenis.css\" data-kid=\"147\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css\" data-kid=\"148\">\n</div>\n>>>>>>> REPLACE\n",
